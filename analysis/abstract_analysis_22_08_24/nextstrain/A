nextstrain RSVA 

augur index --sequences data/N_america.fasta --output results/N_america_A_index.tsv

augur filter --sequences data/N_america.fasta --sequence-index results/N_america_A_index.tsv --metadata data/combined_file_A.tsv --output results/filtered_N_americaA_1930.fasta --group-by country year month --sequences-per-group 20 --min-date 1930

