rule next_export:
    input:
        tree =  "results/{target}_tree.nwk",
        branch_lengths = "results/nextstrain/{target}_branchlens.json",
        traits = "results/nextstrain/{target}_traits.json",
        nt_muts = "results/nextstrain/{target}_ntmuts.json",
        aa_muts = "results/nextstrain/{target}_aamuts.json",
        metadata="results/combined/{target}_meta.tsv",

    output:
        auspice_json = "results/{target}_auspice.json",
    resources:
        mem_mb=8000,
        runtime=120,
    #container: "docker://nextstrain/base"
    group: "nextstrain"
    params:
        colors = "nsconfig/colors.txt",
        lat_longs = "nsconfig/latlongs.txt",
        traits = "nsconfig/traits.txt",
        auspice_config = "nsconfig/auspice_config.json",
	    idcols = "Seq-ID Original-ID name"
    shell:
        """
        augur export v2 \
            --tree {input.tree} \
            --metadata {input.metadata} \
            --node-data {input.branch_lengths} {input.traits} {input.nt_muts} {input.aa_muts} \
            --auspice-config {params.auspice_config} \
            --include-root-sequence \
            --lat-longs {params.lat_longs} \
            --output {output.auspice_json}
            
            
            # --colors {params.colors} \
    
        """

rule get_aamuts_F:
    input:
        tree = 'results/{target}_tree.nwk',
        ancestral = "results/nextstrain/{target}_ntmuts.json",
        alignment = 'results/combined/{target}_all_aligned.fasta',
        gff3 = 'results/refs/{target}.gff3',
    output:
        node_data = "results/escapes/{target}_aamuts_F.fasta"
    params:
        inference = "joint"
    #container: "docker://nextstrain/base"
    group: "escapes"
    resources:
        mem_mb=8000,
        runtime=120,
    shell:
        """
        augur translate \
            --tree {input.tree} \
            --ancestral-sequences {input.ancestral} \
            --reference-sequence {input.gff3} \
            --genes F \
            --alignment-output results/escapes/{wildcards.target}_aamuts_%GENE.fasta
        """

rule parse_escapes_F:
    input:
        fasta="results/escapes/{target}_aamuts_F.fasta",
        samples="results/input/{target}.samples"
    output:
        calls="results/escapes/{target}_escape_calls.txt",
        alleles="results/escapes/{target}_escape_alleles.txt",
        freqs="results/escapes/{target}_escape_allele_frequencies.txt"                
    group: "escapes"
    params:
        outprefix="results/escapes/{target}_escape",
        panel="RSV_mAb_escape_mutations.tsv"
    resources:
        mem_mb=2000,
        runtime=60,
    shell:
        """
        python scripts/pull_escapes.py \
            -p {params.panel} \
            -f {input.fasta} \
            -s {input.samples} \
            -o {params.outprefix}
        """
